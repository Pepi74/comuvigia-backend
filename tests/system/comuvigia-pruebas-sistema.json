    {
      "name": "CP-13 - Flujo E2E completo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"CP-13: Sistema mantiene alertas tras flujo completo\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"CP-13: Alerta de CP-05 persiste en ultimas\", function () {\r",
              "    const body = pm.response.json();\r",
              "    const alertaId = pm.collectionVariables.get('alerta_id');\r",
              "    const encontrada = body.find(a => a.id === alertaId);\r",
              "    pm.expect(encontrada).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"CP-13: Alerta tiene todos los campos requeridos\", function () {\r",
              "    const body = pm.response.json();\r",
              "    const alertaId = pm.collectionVariables.get('alerta_id');\r",
              "    const encontrada = body.find(a => a.id === alertaId);\r",
              "    pm.expect(encontrada).to.have.property('id_camara');\r",
              "    pm.expect(encontrada).to.have.property('mensaje');\r",
              "    pm.expect(encontrada).to.have.property('tipo');\r",
              "    pm.expect(encontrada).to.have.property('hora_suceso');\r",
              "});\r",
              "\r",
              "pm.test(\"CP-13: Alerta marcada como vista en CP-11 tiene estado 1\", function () {\r",
              "    const body = pm.response.json();\r",
              "    const alertaId = pm.collectionVariables.get('alerta_id');\r",
              "    const encontrada = body.find(a => a.id === alertaId);\r",
              "    pm.expect(encontrada.estado).to.eql(1);\r",
              "});\r",
              "\r",
              "pm.test(\"CP-13: Camara creada en CP-08 tiene id válido\", function () {\r",
              "    const camaraId = pm.collectionVariables.get('camara_id');\r",
              "    pm.expect(camaraId).to.be.a('number');\r",
              "});"
